# For local dev (poetry run uvicorn ...). Docker compose overrides DATABASE_URL
# and REDIS_URL automatically — for the containerized stack you only need the keys below.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ollive_chat
REDIS_URL=redis://localhost:6379/0

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=AIza-your-key-here          # optional fallback
OPENAI_API_KEY=sk-your-key-here            # optional fallback
TAVILY_API_KEY=tvly-your-key-here          # powers the web_search tool

# ── Supabase auth (Google OAuth) ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=                        # only if not using JWKS/ES256

# ── Telegram messaging channel ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                         # from @BotFather
TELEGRAM_WEBHOOK_SECRET=                    # any random string you choose

# ── Slack messaging channel ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token          # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-token          # Socket Mode App Token (xapp-)

# ── MCP OAuth integrations ────────────────────────────────────────────────────
# GitHub: create an OAuth App at https://github.com/settings/developers
#   Homepage URL: http://localhost:3000
#   Callback URL: http://localhost:8000/api/v1/mcp/github/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion: create an integration at https://www.notion.so/my-integrations
#   Redirect URI: http://localhost:8000/api/v1/mcp/notion/oauth/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Public URLs used in OAuth redirects (set when running behind a tunnel/proxy)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
