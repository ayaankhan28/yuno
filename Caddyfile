# Auto SSL via Let's Encrypt. sslip.io maps 139-59-10-53.sslip.io → 139.59.10.53
# so no custom domain is needed.
#
# To use your own domain later: replace the hostname below and point DNS A record
# to 139.59.10.53 — Caddy will issue a cert automatically on first request.

139-59-10-53.sslip.io {
    reverse_proxy backend:8000 {
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
        header_up X-Real-IP {remote_host}

        transport http {
            response_header_timeout 600s
        }
    }
}
